{
  "IsEncrypted": false,
  "Values": {
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "AzureWebJobsStorage": "<your-azure-web-jobs-storage-connection-string>",

    "GRAPH_TENANT_ID": "<your-azure-ad-tenant-id>",
    "GRAPH_CLIENT_ID": "<your-azure-ad-app-client-id>",
    "GRAPH_CLIENT_SECRET": "<your-azure-ad-app-client-secret>",
    "GRAPH_USER_EMAIL": "<mailbox-to-monitor@yourdomain.com>",

    "AZURE_OPENAI_ENDPOINT": "https://<your-resource-name>.openai.azure.com/",
    "AZURE_OPENAI_KEY": "<your-azure-openai-api-key>",
    "AZURE_OPENAI_DEPLOYMENT": "gpt-4o-mini",
    "AZURE_OPENAI_DEPLOYMENT_FULL": "gpt-4o",
    "CONFIDENCE_THRESHOLD": "0.7",

    "COSMOS_ENDPOINT": "https://<your-cosmos-account>.documents.azure.com:443/",
    "COSMOS_KEY": "<your-cosmos-primary-key>",
    "COSMOS_DATABASE": "<your-cosmos-database-name>",
    "COSMOS_CONTAINER": "<your-cosmos-container-name>"
  }
}
